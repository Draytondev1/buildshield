# BuildShield Environment Variables
# Copy this file to .env.local and fill in your actual values

# Clerk Authentication
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_YOUR_CLERK_PUBLISHABLE_KEY
CLERK_SECRET_KEY=sk_test_YOUR_CLERK_SECRET_KEY
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# Clerk Webhook Secret (for user creation webhook)
CLERK_WEBHOOK_SECRET=whsec_YOUR_CLERK_WEBHOOK_SECRET

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJYOUR_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=eyJYOUR_SERVICE_ROLE_KEY

# Anthropic Claude API
ANTHROPIC_API_KEY=sk-ant-api03-YOUR_ANTHROPIC_API_KEY

# Visual Crossing Weather API
VISUAL_CROSSING_API_KEY=YOUR_VISUAL_CROSSING_API_KEY

# Application
NEXT_PUBLIC_APP_URL=http://localhost:3000
